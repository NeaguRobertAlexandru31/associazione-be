// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MemberCategory {
  ordinario
  under26
  sostenitore
}

enum MemberGender {
  m
  f
  altro
}

enum DocType {
  ci
  passaporto
  patente
}

enum MemberStatus {
  in_attesa_pagamento
  pagamento_in_corso
  attivo
  rifiutato
}

enum PaymentMethod {
  online
  contanti
}

enum GuardianRelation {
  genitore
  tutore_legale
}

enum ProjectCategory {
  cultura
  tradizione
  sociale
  educazione
}

enum ProjectStatus {
  ongoing
  completed
}

enum DonationFrequency {
  once
  monthly
}

enum DonationMethod {
  card
  bank
}

model Member {
  id                 String        @id @default(uuid())
  isMinor            Boolean
  category           MemberCategory
  firstName          String
  lastName           String
  fiscalCode         String
  birthDate          DateTime
  birthPlace         String
  gender             MemberGender
  docType            DocType
  docNumber          String
  docExpiry          DateTime
  email              String
  phone              String
  addressStreet      String
  addressZip         String
  addressCity        String
  addressProvince    String
  status             MemberStatus  @default(in_attesa_pagamento)
  membershipYear     Int
  paymentMethod      PaymentMethod
  privacyBase        Boolean
  privacyNewsletter  Boolean       @default(false)
  privacyThirdParties Boolean      @default(false)
  passwordHash       String?
  guardian           Guardian?
  donations          Donation[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?

  @@unique([fiscalCode, membershipYear])
}

model Guardian {
  id         String          @id @default(uuid())
  memberId   String          @unique
  member     Member          @relation(fields: [memberId], references: [id], onDelete: Cascade)
  firstName  String
  lastName   String
  fiscalCode String
  relation   GuardianRelation
  docType    DocType
  docNumber  String
  docExpiry  DateTime
}

model Event {
  id          String   @id @default(uuid())
  slug        String?  @unique
  name        String
  date        DateTime
  time        String
  location    String
  description String?
  images      String[]
  cover       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Article {
  id         String   @id @default(uuid())
  name       String
  categories String[]
  blocks     Json     @default(dbgenerated("'[]'::jsonb"))
  cover      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  category    ProjectCategory
  status      ProjectStatus
  images      String[]
  cover       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Product {
  id            String   @id @default(uuid())
  title         String
  description   String
  category      String
  author        String?
  price         Decimal
  originalPrice Decimal?
  isNew         Boolean?
  images        String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Donation {
  id              String            @id @default(uuid())
  donorName       String?
  donorEmail      String?
  amount          Decimal
  frequency       DonationFrequency
  method          DonationMethod
  stripeSessionId String?
  memberId        String?
  member          Member?           @relation(fields: [memberId], references: [id])
  createdAt       DateTime          @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

model AdminUser {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  passwordHash String
  role         AdminRole     @default(ADMIN)
  boardRoles   String[]
  invitesSent  AdminInvite[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AdminInvite {
  id          String    @id @default(uuid())
  token       String    @unique @default(uuid())
  createdBy   AdminUser @relation(fields: [createdById], references: [id])
  createdById String
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
}

model OtpCode {
  id        String    @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}
